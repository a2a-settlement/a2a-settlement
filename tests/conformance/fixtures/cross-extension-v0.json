      "mandate_verification": {
        "authored_by": "Christian Magorrian / A2CN Protocol",
        "namespace": "a2cn:record:v0.2",
        "required": [
          "layer",
          "protocol",
          "version",
          "session_id",
          "mandate_hash",
          "initiator_did",
          "responder_did",
          "transaction_record_hash",
          "record_id"
        ],
        "optional": [
          "requires_human_approval_above",
          "approval_receipt_hash",
          "dispute_notice_id"
        ],
        "verifier_checks": [
          "transaction_record_hash: recompute SHA-256 over JCS-canonical transaction record from session inputs; must match.",
          "mandate_hash: resolve each party DID document, fetch mandate credential, recompute hash; confirms both agents operated within authorised bounds at session time.",
          "record_id: verify UUID v5 derivation from session_id using A2CN namespace a2cn:record:v0.2."
        ],
        "does_not_carry": [
          "mandate credential",
          "session message content",
          "offer chain"
        ],
        "note": "dispute_notice_id SHOULD be present for any entry whose terminal state is DISPUTE_RESOLVED, so the chain is reconstructable from the entry alone. It is the join point with the dispute_resolution layer; both point back to transaction_record_hash for chain continuity."
      },
      "dispute_resolution": {
        "authored_by": "Concordia Protocol",
        "status": "pending_definition",
        "expected_fields": [
          "resolver_did",
          "resolution_outcome",
          "fulfilled_with_mediation_receipt_hash"
        ],
        "note": "Points back to transaction_record_hash for chain continuity. Field shape pending Concordia definition."
      }
    },
    "verification_recipe": [
      "1. Extract the jws field; the remaining object is the unsigned vector.",
      "2. Compute rfc8785.dumps(unsigned_vector); this yields canonical bytes.",
      "3. Split jws on '.' into [header_b64, payload_b64, signature_b64].",
      "4. Confirm base64url-decode(payload_b64) == canonical_bytes from step 2.",
      "5. Resolve signer_did to public key via did:web:api.algovoi.co.uk -> /.well-known/did.json#verascore or /.well-known/jwks.json.",
      "6. Verify Ed25519 signature over '{header_b64}.{payload_b64}'."
    ]
  },
